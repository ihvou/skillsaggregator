{
  "name": "skillsaggregator",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check:edge-shared": "node scripts/check-edge-shared-sync.mjs",
    "sync:edge-shared": "node scripts/check-edge-shared-sync.mjs --write",
    "add:moderator": "node scripts/add-moderator.mjs",
    "collect:articles": "node scripts/run-article-collection.mjs",
    "collect:local": "COLLECT_TARGET=local bash scripts/nightly-collect.sh",
    "collect:hosted": "COLLECT_TARGET=hosted bash scripts/nightly-collect.sh",
    "collect:hosted:smoke": "COLLECT_TARGET=hosted COLLECT_HARD_TIMEOUT_SEC=900 bash scripts/nightly-collect.sh --category badminton --skill forehand-smash",
    "discover:sources": "node scripts/discover-sources.mjs",
    "collect:health": "node scripts/check-supabase-health.mjs",
    "collect:report": "node scripts/nightly-report.mjs",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "db:migrate:safe": "bash scripts/db-migrate-safe.sh",
    "db:replay-logs": "node scripts/replay-from-logs.mjs",
    "transcripts:backfill-cache": "node scripts/backfill-transcripts-from-cache.mjs",
    "transcripts:fetch-missing": "node scripts/fetch-missing-transcripts.mjs",
    "suggestions:apply-pending-link-adds": "node scripts/apply-pending-link-adds-unpublished.mjs",
    "h1": "node scripts/h1_youtube_density.mjs",
    "h2": "node scripts/h2_transcript_availability.mjs",
    "h3": "node scripts/h3_score_fixtures.mjs",
    "h4": "node scripts/h4_triangulation_agreement.mjs",
    "test:e2e:web": "npm --workspace apps/web run test:e2e",
    "test:db": "supabase test db",
    "ci": "npm run check:edge-shared && npm run lint && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "cheerio": "1.0.0",
    "playwright": "^1.59.1",
    "web-streams-polyfill": "~3.3.3"
  }
}
